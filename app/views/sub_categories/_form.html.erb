<%= form_with model: sub_category, class: "categories-form" do |f| %>
  <% if sub_category.errors.any? %>
    <div class="form-errors">
      <ul>
        <% sub_category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :category_id, "親カテゴリー" %>
    <%= f.collection_select :category_id,
                            current_user.categories.order(:id),
                            :id,
                            :name,
                            { prompt: "選択してください" },
                            class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :name, "サブカテゴリー名" %>
    <%= f.text_field :name,
                     class: "form-control",
                     maxlength: 20 %>
  </div>

  <div class="categories-form-actions">
    <%= f.submit class: "btn-primary" %>

    <%= link_to "一覧へ戻る",
                sub_categories_path,
                class: "btn-secondary" %>
  </div>
<% end %>
