<%= form_with model: transaction, class: 'transaction-form' do |f| %>

  <% if transaction.errors.any? %>
    <div class="error-messages">
      <ul>
        <% transaction.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
  <%= label_tag :template_id, 'テンプレートを使う' %>

  <%= select_tag :template_id,
               options_for_select(
                 current_user.templates.order(created_at: :desc).map { |template|
                   [
                     template.display_name,
                     template.id,
                     {
                       data: {
                         transaction_type: template.transaction_type,
                         amount: template.amount,
                         sub_category_id: template.sub_category_id,
                         memo: template.memo
                       }
                     }
                   ]
                 }
               ),
               include_blank: '選択してください',
               class: 'form-control',
               id: 'template-select' %>
</div>

  <div class="form-group">
    <%= f.label :transaction_type, '種別' %>

    <%= f.select :transaction_type,
                 Transaction.transaction_types.keys.map { |key|
                   [key == 'expense' ? '支出' : '収入', key]
                 },
                 {},
                 class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= f.label :transacted_at, '日付' %>

    <%= f.date_field :transacted_at,
                     class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= f.label :amount, '金額' %>

    <%= f.number_field :amount,
                       class: 'form-control',
                       min: 1,
                       max: 999999 %>
  </div>

<div class="form-group">
  <%= f.label :sub_category_id, 'カテゴリー' %>

  <%= f.select :sub_category_id,
               grouped_options_for_select(
                 current_user.categories.includes(:sub_categories).map do |category|
                   [
                     category.name,
                     category.sub_categories.map { |sub| [sub.name, sub.id] }
                   ]
                 end,
                 transaction.sub_category_id
               ),
               { prompt: '選択してください' },
               class: 'form-control' %>
</div>
  <div class="form-group">
    <%= f.label :memo, 'メモ' %>

    <%= f.text_area :memo,
                    class: 'form-control',
                    rows: 4 %>
  </div>

  <div class="form-group">
  <label class="checkbox-label">
    <%= check_box_tag :save_as_template, '1' %>
    テンプレートとして保存
  </label>
</div>

  <div class="form-actions">
    <%= f.submit class: 'btn btn-primary' %>
  </div>

<% end %>
