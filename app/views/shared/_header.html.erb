<header class="header">
  <div class="wrap">
    <div class="flex header__inner">
      <%# ロゴエリア %>
      <%= link_to root_path, class: "contents" do %>
        <h1 class="header__logo">
          <%= image_tag "logo_pai-budget-book_01.webp",
                        alt: "PaiBudgetBook",
                        class: "header__logo-image" %>
        </h1>
      <% end %>

      <%# ナビゲーション %>
      <nav class="header__nav">
        <ul class="flex header__nav-list">
          <% if user_signed_in? %>
  <% if current_user.admin? %>
    <li class="header__nav-item">
      <%= link_to "ユーザー管理", admin_users_path, class: "header__nav-link" %>
    </li>

    <li class="header__nav-item">
      <%= link_to "カテゴリー管理", admin_categories_path, class: "header__nav-link" %>
    </li>

    <li class="header__nav-item">
      <%= link_to "管理画面", admin_path, class: "header__nav-link" %>
    </li>
  <% else %>
    <li class="header__nav-item">
      <%= link_to "ダッシュボード", dashboard_path, class: "header__nav-link" %>
    </li>

    <li class="header__nav-item">
      <%= link_to "収支一覧", transactions_path, class: "header__nav-link" %>
    </li>

    <li class="header__nav-item">
      <%= link_to "カテゴリー", categories_path, class: "header__nav-link" %>
    </li>
  <% end %>

  <li class="header__nav-item">
    <%= link_to "ログアウト",
                destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "header__nav-link" %>
  </li>
<% else %>
  <li class="header__nav-item">
    <%= link_to "ログイン", new_user_session_path, class: "header__nav-link" %>
  </li>

  <li class="header__nav-item">
    <%= link_to "新規登録", new_user_registration_path, class: "header__nav-link" %>
  </li>
  <% end %>
        </ul>
      </nav>
    </div>
  </div>
</header>
