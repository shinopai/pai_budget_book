<div class="auth-page">
  <div class="wrap">

    <h1 class="auth-page__title">
      パスワード再設定
    </h1>

    <%= form_for(resource,
                 as: resource_name,
                 url: password_path(resource_name),
                 html: {
                   method: :post,
                   class: "form"
                 }) do |f| %>

      <%= render "devise/shared/error_messages",
                 resource: resource %>

      <div class="form-group">
        <%= f.label :email, "メールアドレス" %>

        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "form-control" %>
      </div>

      <div class="form-actions">
        <%= f.submit "再設定メールを送信",
                     class: "btn btn-primary" %>
      </div>

    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
