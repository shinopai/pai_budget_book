<div class="categories">
  <div class="wrap">

    <div class="categories__header flex">

      <h1 class="categories__title">
        カテゴリー一覧
      </h1>

      <%= link_to "新規作成",
                  new_category_path,
                  class: "btn btn-primary" %>

    </div>

    <% if @categories.any? %>

      <table class="table-common">
        <thead>
          <tr>
            <th>ID</th>
            <th>カテゴリー名</th>
            <th>作成日</th>
            <th>操作</th>
          </tr>
        </thead>

        <tbody>
          <% @categories.each do |category| %>
            <tr>

              <td><%= category.id %></td>

              <td><%= category.name %></td>

              <td>
                <%= l(category.created_at, format: :short) %>
              </td>

              <td class="table-common__actions">

                <%= link_to "編集",
                            edit_category_path(category),
                            class: "btn btn-secondary btn-sm" %>

                <%= link_to "削除",
                            category_path(category),
                            data: {
                              turbo_method: :delete,
                              turbo_confirm: "「#{category.name}」を削除しますか？"
                            },
                            class: "btn btn-danger btn-sm" %>

              </td>

            </tr>
          <% end %>
        </tbody>
      </table>

    <% else %>

      <p class="categories__empty">
        カテゴリーが登録されていません。
      </p>

    <% end %>

  </div>
</div>
