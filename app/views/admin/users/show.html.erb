<div class="table-common-wrap">
  <div class="wrap">
<h2>ユーザー詳細</h2>
<table class="table-common">
  <tbody>
    <tr>
      <th>ID</th>
      <td><%= @user.id %></td>
    </tr>

    <tr>
      <th>名前</th>
      <td><%= @user.name %></td>
    </tr>

    <tr>
      <th>メールアドレス</th>
      <td><%= @user.email %></td>
    </tr>

    <tr>
      <th>権限</th>
      <td><%= @user.admin? ? '管理者' : '一般ユーザー' %></td>
    </tr>

    <tr>
      <th>登録日時</th>
      <td><%= l(@user.created_at, format: :long) %></td>
    </tr>

    <tr>
      <th>更新日時</th>
      <td><%= l(@user.updated_at, format: :long) %></td>
    </tr>
  </tbody>
</table>

<p>
  <%= link_to 'ユーザー一覧へ戻る', admin_users_path %>
</p>
  </div>
</div>
