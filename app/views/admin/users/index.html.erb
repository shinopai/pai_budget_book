<div class="admin-users">
  <div class="wrap">

    <h1 class="admin-users__title">
      ユーザー一覧
    </h1>

    <table class="table-common">
      <thead>
        <tr>
          <th>ID</th>
          <th>名前</th>
          <th>メールアドレス</th>
          <th>権限</th>
          <th>登録日</th>
          <th></th>
        </tr>
      </thead>

      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><%= user.admin? ? "管理者" : "一般" %></td>
            <td><%= l(user.created_at, format: :short) %></td>

            <td class="table-common__actions">
              <%= link_to "詳細",
                          admin_user_path(user),
                          class: "btn btn-secondary btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

  </div>
</div>
